# ============================================================
# WorkSense - Variables de Entorno
# ============================================================
# INSTRUCCIONES:
#   1. Copia este archivo como ".env" en la raiz del proyecto
#   2. Completa los valores reales (nunca subir .env al repo)
#   3. El .env ya esta en .gitignore
# ============================================================

# ── Supabase ─────────────────────────────────────────────────
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_ANON_KEY=tu_anon_public_key_aqui

# ── Google Maps ──────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=tu_google_maps_api_key_aqui

# ── Configuracion de la App ──────────────────────────────────
APP_ENV=development            # development | staging | production
APP_DEBUG=true

# ── AI Pipeline ──────────────────────────────────────────────
# Estos valores pueden sobreescribir los defaults de ai_thresholds.dart
AI_MIN_CONFIDENCE=0.7
AI_ANALYSIS_INTERVAL_SECONDS=30
AI_INACTIVITY_THRESHOLD_SECONDS=60
